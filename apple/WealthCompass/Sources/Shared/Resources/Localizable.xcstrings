            "state" : "translated",
            "value" : "يؤدي هذا إلى إزالة %@ من فئات %@ المخصصة. ستحتفظ المعاملات الحالية التي تستخدم هذه الفئة بتصنيفها الحالي."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch wird %@ aus Ihren benutzerdefinierten %@-Kategorien entfernt. Bestehende Transaktionen, die diese Kategorie verwenden, behalten ihre aktuelle Bezeichnung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "This removes %1$@ from your custom %2$@ categories. Existing transactions using this category will keep their current label."
