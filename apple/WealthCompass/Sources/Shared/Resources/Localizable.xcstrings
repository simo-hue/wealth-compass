    "PDF statements are supported for Trade Republic only. For Revolut, import the CSV statement instead." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كشوف PDF مدعومة لـ Trade Republic فقط. أما لـ Revolut، فاستورد كشف CSV بدلاً من ذلك."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Els extractes PDF només són compatibles amb Trade Republic. Per a Revolut, importa l'extracte CSV."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Výpisy PDF jsou podporovány pouze pro Trade Republic. Pro Revolut importujte místo toho výpis CSV."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PDF-kontoudtog understøttes kun for Trade Republic. For Revolut skal du i stedet importere CSV-kontoudtoget."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PDF-Kontoauszüge werden nur für Trade Republic unterstützt. Importiere für Revolut stattdessen den CSV-Kontoauszug."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Τα αντίγραφα κίνησης PDF υποστηρίζονται μόνο για το Trade Republic. Για το Revolut, εισαγάγετε το αντίγραφο κίνησης CSV."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los extractos PDF solo son compatibles con Trade Republic. Para Revolut, importa el extracto CSV en su lugar."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los estados de cuenta PDF solo son compatibles con Trade Republic. Para Revolut, importa el estado de cuenta CSV en su lugar."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PDF-tiliotteita tuetaan vain Trade Republicille. Tuo Revolutille sen sijaan CSV-tiliote."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les relevés PDF sont pris en charge uniquement pour Trade Republic. Pour Revolut, importez plutôt le relevé CSV."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "דפי חשבון PDF נתמכים עבור Trade Republic בלבד. עבור Revolut, ייבא במקום זאת את דף החשבון בפורמט CSV."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PDF विवरण केवल Trade Republic के लिए समर्थित हैं। Revolut के लिए, इसके बजाय CSV विवरण आयात करें।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PDF izvodi podržani su samo za Trade Republic. Za Revolut umjesto toga uvezite CSV izvod."
          }
        },
        "hu" : {
          "stringUnit" : {
