    "Couldn't reach iCloud to delete your data. Check your connection and try again." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تعذّر الوصول إلى iCloud لحذف بياناتك. تحقق من اتصالك وحاول مرة أخرى."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No s'ha pogut connectar amb iCloud per suprimir les dades. Comprova la connexió i torna-ho a provar."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nepodařilo se připojit k iCloud pro smazání vašich dat. Zkontrolujte připojení a zkuste to znovu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kunne ikke få forbindelse til iCloud for at slette dine data. Tjek din forbindelse, og prøv igen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud konnte zum Löschen deiner Daten nicht erreicht werden. Überprüfe deine Verbindung und versuche es erneut."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Δεν ήταν δυνατή η σύνδεση με το iCloud για τη διαγραφή των δεδομένων σας. Ελέγξτε τη σύνδεσή σας και δοκιμάστε ξανά."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No se pudo conectar con iCloud para eliminar tus datos. Comprueba tu conexión e inténtalo de nuevo."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No se pudo conectar con iCloud para eliminar tus datos. Revisa tu conexión e inténtalo de nuevo."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloudiin ei saatu yhteyttä tietojesi poistamiseksi. Tarkista yhteytesi ja yritä uudelleen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impossible de joindre iCloud pour supprimer vos données. Vérifiez votre connexion et réessayez."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "לא ניתן היה להתחבר ל-iCloud כדי למחוק את הנתונים שלך. בדוק את החיבור ונסה שוב."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपका डेटा हटाने के लिए iCloud तक नहीं पहुँचा जा सका। अपना कनेक्शन जाँचें और फिर से प्रयास करें।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nije bilo moguće pristupiti iCloudu za brisanje vaših podataka. Provjerite vezu i pokušajte ponovno."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
