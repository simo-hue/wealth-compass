    "Keys are stored securely in Keychain and only used to refresh market prices from this %@." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتم تخزين المفاتيح بشكل آمن في Keychain وتستخدم فقط لتحديث أسعار السوق من %@ هذا."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les claus s'emmagatzemen de manera segura al Keychain i només s'utilitzen per actualitzar els preus del mercat des d'aquest %@."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klíče jsou bezpečně uloženy v Keychain a slouží pouze k obnovení tržních cen z tohoto %@."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nøgler opbevares sikkert i nøglering og bruges kun til at opdatere markedspriser fra denne %@."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schlüssel werden sicher im Schlüsselbund gespeichert und nur zur Aktualisierung der Marktpreise von diesem %@ verwendet."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Τα κλειδιά αποθηκεύονται με ασφάλεια στο Keychain και χρησιμοποιούνται μόνο για την ανανέωση των τιμών της αγοράς από αυτό το %@."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las claves se almacenan de forma segura en Keychain y solo se utilizan para actualizar los precios de mercado desde este %@."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las claves se almacenan de forma segura en Keychain y solo se utilizan para actualizar los precios de mercado desde este %@."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avaimet säilytetään turvallisesti Keychainissa ja niitä käytetään vain markkinahintojen päivittämiseen tästä %@."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les clés sont stockées en toute sécurité dans le trousseau et utilisées uniquement pour actualiser les prix du marché à partir de ce %@."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "המפתחות מאוחסנים בצורה מאובטחת במחזיק מפתחות ומשמשים רק לרענון מחירי שוק מ-%@ זה."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "चाबियाँ किचेन में सुरक्षित रूप से संग्रहीत की जाती हैं और केवल इस %@ से बाजार कीमतों को ताज़ा करने के लिए उपयोग की जाती हैं।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ključevi su sigurno pohranjeni u Keychainu i koriste se samo za osvježavanje tržišnih cijena iz ovog %@."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A kulcsokat biztonságosan tárolja a Keychain, és csak a piaci árak frissítésére használjuk fel ettől a %@-tól."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
