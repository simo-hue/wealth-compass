    "Latest ECB reference rates are effective %@.\n\nThe rates are cached locally for offline use." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أحدث المعدلات المرجعية للبنك المركزي الأوروبي سارية %@.\n\nيتم تخزين الأسعار مؤقتًا محليًا للاستخدام دون اتصال بالإنترنت."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Els darrers tipus de referència del BCE són efectius %@.\n\nLes tarifes s'emmagatzemen a la memòria cau localment per utilitzar-les fora de línia."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nejnovější referenční sazby ECB jsou platné od %@.\n\nSazby jsou lokálně ukládány do mezipaměti pro použití offline."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seneste ECB-referencerenter er effektive %@.\n\nPriserne cachelagres lokalt til offline brug."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die aktuellen EZB-Referenzzinssätze gelten ab %@.\n\nDie Tarife werden für die Offline-Nutzung lokal zwischengespeichert."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Τα τελευταία επιτόκια αναφοράς της ΕΚΤ ισχύουν %@.\n\nΟι τιμές αποθηκεύονται τοπικά για χρήση εκτός σύνδεσης."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los últimos tipos de referencia del BCE entran en vigor el %@.\n\nLas tarifas se almacenan en caché localmente para su uso sin conexión."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los últimos tipos de referencia del BCE entran en vigor el %@.\n\nLas tarifas se almacenan en caché localmente para su uso sin conexión."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Viimeisimmät EKP:n viitekorot ovat voimassa %@.\n\nHinnat tallennetaan paikallisesti välimuistiin offline-käyttöä varten."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les derniers taux de référence de la BCE sont en vigueur le %@.\n\nLes tarifs sont mis en cache localement pour une utilisation hors ligne."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "שיעורי הייחוס העדכניים ביותר של ה-ECB הם בתוקף %@.\n\nהתעריפים נשמרים במטמון מקומי לשימוש לא מקוון."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "नवीनतम ईसीबी संदर्भ दरें प्रभावी %@ हैं।\n\nऑफ़लाइन उपयोग के लिए दरें स्थानीय रूप से कैश की जाती हैं।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Najnovije referentne stope ECB-a stupaju na snagu %@.\n\nCijene se pohranjuju lokalno za izvanmrežnu upotrebu."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Az EKB legutóbbi referenciakamatlábai %@ érvényesek.\n\nA díjak helyi gyorsítótárban vannak offline használatra."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suku bunga referensi ECB terbaru efektif %@.\n\nTarif di-cache secara lokal untuk penggunaan offline."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gli ultimi tassi di riferimento della BCE sono in vigore %@.\n\nLe tariffe vengono memorizzate nella cache locale per l'utilizzo offline."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "最新の ECB 参照レートは %@ で有効です。\n\nレートはオフラインで使用できるようにローカルにキャッシュされます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "최신 ECB 기준금리는 %@ 유효합니다.\n\n요금은 오프라인 사용을 위해 로컬로 캐시됩니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kadar rujukan ECB terkini berkuat kuasa %@.\n\nKadar dicache secara tempatan untuk kegunaan luar talian."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De siste ECB-referanserentene er effektive %@.\n\nPrisene bufres lokalt for offline bruk."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De meest recente referentierentetarieven van de ECB zijn van kracht vanaf %@.\n\nDe tarieven worden lokaal in de cache opgeslagen voor offline gebruik."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Najnowsze stopy referencyjne EBC obowiązują %@.\n\nStawki są zapisywane lokalnie w pamięci podręcznej i można z nich korzystać w trybie offline."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As taxas de referência mais recentes do BCE entram em vigor em %@.\n\nAs taxas são armazenadas em cache localmente para uso offline."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As taxas de referência mais recentes do BCE entram em vigor em %@.\n\nAs taxas são armazenadas em cache localmente para utilização offline."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cele mai recente rate de referință ale BCE sunt în vigoare %@.\n\nTarifele sunt stocate în cache local pentru utilizare offline."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Последние базовые ставки ЕЦБ действуют %@.\n\nТарифы кэшируются локально для использования в автономном режиме."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Najnovšie referenčné sadzby ECB sú platné od %@.\n\nSadzby sa ukladajú do lokálnej vyrovnávacej pamäte na použitie offline."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ECB:s senaste referensräntor är effektiva %@.\n\nPriserna cachelagras lokalt för offlineanvändning."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
