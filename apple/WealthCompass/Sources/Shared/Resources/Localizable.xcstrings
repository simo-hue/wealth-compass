        },
        "da" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "The iCloud account changed. Sync was disabled to prevent data from crossing accounts. Enable it again to sync with the current account."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das iCloud-Konto hat sich geändert. Die Synchronisierung wurde deaktiviert, um zu verhindern, dass Daten kontenübergreifend übertragen werden. Aktivieren Sie es erneut, um die Synchronisierung mit dem aktuellen Konto durchzuführen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "The iCloud account changed. Sync was disabled to prevent data from crossing accounts. Enable it again to sync with the current account."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La cuenta de iCloud cambió. La sincronización se deshabilitó para evitar que los datos crucen cuentas. Habilítelo nuevamente para sincronizarlo con la cuenta actual."
          }
        },
        "es-419" : {
