          "stringUnit" : {
            "state" : "translated",
            "value" : "Se importaron %lld transacciones, %lld cronogramas recurrentes, %lld inversiones, %lld tenencias de criptomonedas, %lld pasivos y %lld instantáneas."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tuotiin %lld tapahtumaa, %lld toistuvia aikatauluja, %lld sijoituksia, %lld kryptoomistuksia, %lld velkoja ja %lld tilannekuvaa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
