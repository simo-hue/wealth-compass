    "The schedule was saved, but notifications are not authorized. You can enable them in iOS Settings and then edit this schedule." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم حفظ الجدول الزمني، لكن الإشعارات غير مسموح بها. يمكنك تمكينها في إعدادات iOS ثم تعديل هذا الجدول الزمني."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Zeitplan wurde gespeichert, aber Benachrichtigungen sind nicht autorisiert. Sie können sie in den iOS-Einstellungen aktivieren und dann diesen Zeitplan bearbeiten."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La programación se guardó, pero las notificaciones no están autorizadas. Puede habilitarlos en la configuración de iOS y luego editar este programa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le planning a été enregistré, mais les notifications ne sont pas autorisées. Vous pouvez les activer dans les paramètres iOS, puis modifier ce calendrier."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La pianificazione è stata salvata, ma le notifiche non sono autorizzate. Puoi abilitarli nelle Impostazioni iOS e quindi modificare questa pianificazione."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "计划已保存，但未授权通知。您可以在 iOS 设置中启用它们，然后编辑此计划。"
          }
        }
      }
    },
