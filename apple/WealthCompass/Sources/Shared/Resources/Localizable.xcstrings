    "The network is unavailable. Local changes are saved and will retry automatically." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الشبكة غير متوفرة. يتم حفظ التغييرات المحلية وستتم إعادة المحاولة تلقائيًا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Netzwerk ist nicht verfügbar. Lokale Änderungen werden gespeichert und automatisch erneut versucht."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La red no está disponible. Los cambios locales se guardan y se volverán a intentar automáticamente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le réseau n'est pas disponible. Les modifications locales sont enregistrées et seront réessayées automatiquement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La rete non è disponibile. Le modifiche locali vengono salvate e verranno riprovate automaticamente."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "网络不可用。本地更改已保存并会自动重试。"
          }
        }
      }
    },
