        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Birleştirme, yeni kayıtlar ekler ve eşleşen kimlikleri günceller. Değiştir, içe aktarmadan önce mevcut yerel finans verilerini temizler."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Злиття додає нові записи та оновлює відповідні ідентифікатори. Замінити видаляє поточні місцеві фінансові дані перед імпортом."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hợp nhất thêm bản ghi mới và cập nhật ID phù hợp. Thay thế xóa dữ liệu tài chính địa phương hiện tại trước khi nhập."
          }
        },
        "zh-Hans" : {
