    "ECB reference rates are refreshed automatically and cached locally for offline use." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتم تحديث الأسعار المرجعية للبنك المركزي الأوروبي تلقائيًا ويتم تخزينها مؤقتًا محليًا للاستخدام دون اتصال بالإنترنت."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Els tipus de referència del BCE s'actualitzen automàticament i s'emmagatzemen a la memòria cau localment per utilitzar-los fora de línia."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Referenční sazby ECB se automaticky obnovují a ukládají se do místní mezipaměti pro použití offline."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ECB's referencekurser opdateres automatisk og cachelagres lokalt til offlinebrug."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Referenzzinssätze der EZB werden automatisch aktualisiert und lokal für die Offline-Nutzung zwischengespeichert."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Τα επιτόκια αναφοράς της ΕΚΤ ανανεώνονται αυτόματα και αποθηκεύονται στην προσωρινή μνήμη τοπικά για χρήση εκτός σύνδεσης."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los tipos de referencia del BCE se actualizan automáticamente y se almacenan en caché localmente para su uso sin conexión."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los tipos de referencia del BCE se actualizan automáticamente y se almacenan en caché localmente para su uso sin conexión."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "EKP:n viitekorot päivitetään automaattisesti ja tallennetaan paikallisesti välimuistiin offline-käyttöä varten."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les taux de référence de la BCE sont actualisés automatiquement et mis en cache localement pour une utilisation hors ligne."
