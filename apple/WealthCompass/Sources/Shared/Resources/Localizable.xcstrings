    "Everything you own, owe, earn, and spend." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كل ما تملكه، وتدين به، وتكسبه، وتنفقه."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tot el que posseïu, deu, guanyeu i gasteu."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vše, co vlastníte, dlužíte, vyděláváte a utrácíte."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alt hvad du ejer, skylder, tjener og bruger."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alles, was Sie besitzen, schulden, verdienen und ausgeben."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ό,τι κατέχετε, οφείλετε, κερδίζετε και ξοδεύετε."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todo lo que posee, debe, gana y gasta."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todo lo que posee, debe, gana y gasta."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaikki mitä omistat, velkaa, ansaitset ja kulutat."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tout ce que vous possédez, devez, gagnez et dépensez."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "כל מה שאתה מחזיק, חייב, מרוויח ומוציא."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "वह सब कुछ जो आपके पास है, देना है, कमाना है और खर्च करना है।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sve što posjedujete, dugujete, zaradite i potrošite."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Minden, amivel rendelkezel, tartozol, keresel és költesz."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Segala sesuatu yang Anda miliki, utang, hasilkan, dan belanjakan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tutto ciò che possiedi, devi, guadagni e spendi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたが所有しているもの、借りているもの、稼いでいるもの、支出しているものすべて。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당신이 소유하고, 빚지고, 벌고, 소비하는 모든 것."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Semua yang anda miliki, hutang, peroleh dan belanjakan."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alt du eier, skylder, tjener og bruker."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alles wat u bezit, verschuldigd bent, verdient en uitgeeft."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wszystko, co posiadasz, jesteś winien, zarabiasz i wydajesz."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tudo o que você possui, deve, ganha e gasta."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tudo o que possui, deve, ganha e gasta."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
