          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mesclar adiciona novos registros e atualiza IDs correspondentes. Substituir limpa os dados financeiros locais atuais antes de importar."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
