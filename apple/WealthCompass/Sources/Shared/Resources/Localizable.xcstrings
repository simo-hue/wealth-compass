    "Done" : {

    },
    "Due schedules are recorded automatically while the app is active and caught up the next time it opens." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتم تسجيل جداول الاستحقاق تلقائيًا عندما يكون التطبيق نشطًا ويتم تسجيلها في المرة التالية التي يتم فيها فتحه."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Els horaris pendents s'enregistren automàticament mentre l'aplicació està activa i es recupera la propera vegada que s'obri."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plány termínů se zaznamenávají automaticky, když je aplikace aktivní, a dohoní se při příštím otevření."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forfaldsplaner optages automatisk, mens appen er aktiv, og indhentes, næste gang den åbner."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fällige Zeitpläne werden automatisch erfasst, während die App aktiv ist, und beim nächsten Öffnen nachgeholt."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Τα οφειλόμενα χρονοδιαγράμματα καταγράφονται αυτόματα ενώ η εφαρμογή είναι ενεργή και καλύπτονται την επόμενη φορά που θα ανοίξει."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los horarios de vencimiento se registran automáticamente mientras la aplicación está activa y se actualizan la próxima vez que se abre."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los horarios de vencimiento se registran automáticamente mientras la aplicación está activa y se actualizan la próxima vez que se abre."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erääntymisaikataulut tallennetaan automaattisesti, kun sovellus on aktiivinen, ja ne ovat kiinni, kun se avataan seuraavan kerran."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les horaires d'échéance sont enregistrés automatiquement pendant que l'application est active et rattrapés à la prochaine ouverture."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "לוחות זמנים שנקבעו מתועדים באופן אוטומטי בזמן שהאפליקציה פעילה ומתעדכנים בפעם הבאה שהיא נפתחת."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ऐप सक्रिय होने पर नियत शेड्यूल स्वचालित रूप से रिकॉर्ड किए जाते हैं और अगली बार खुलने पर पकड़ में आ जाते हैं।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rasporedi se automatski bilježe dok je aplikacija aktivna i nadoknađuju se kada se sljedeći put otvori."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Az esedékes ütemezések automatikusan rögzítésre kerülnek, amikor az alkalmazás aktív, és a következő megnyitáskor utolérik."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jadwal jatuh tempo dicatat secara otomatis saat aplikasi aktif dan diikuti saat aplikasi dibuka berikutnya."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le scadenze vengono registrate automaticamente mentre l'app è attiva e aggiornate alla successiva apertura."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "期限のスケジュールはアプリがアクティブな間自動的に記録され、次回アプリを開いたときに更新されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "마감 일정은 앱이 활성화되어 있는 동안 자동으로 기록되며 다음에 앱을 열 때 따라잡습니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jadual yang sepatutnya direkodkan secara automatik semasa apl aktif dan terperangkap pada kali berikutnya ia dibuka."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forfallsplaner registreres automatisk mens appen er aktiv og fanges opp neste gang den åpnes."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inleverschema's worden automatisch geregistreerd terwijl de app actief is en worden ingehaald de volgende keer dat deze wordt geopend."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Harmonogramy terminów są rejestrowane automatycznie, gdy aplikacja jest aktywna i uwzględniane przy następnym otwarciu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Os cronogramas de vencimento são registrados automaticamente enquanto o aplicativo está ativo e atualizados na próxima vez que for aberto."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Os planos de vencimento são registados automaticamente enquanto a aplicação está ativa e atualizados na próxima vez que for aberta."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Programele scadente sunt înregistrate automat în timp ce aplicația este activă și reținută data viitoare când se deschide."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "График выполнения записывается автоматически, пока приложение активно, и обновляется при следующем его открытии."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plány termínov sa zaznamenávajú automaticky, keď je aplikácia aktívna, a zachytia sa pri ďalšom otvorení."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
