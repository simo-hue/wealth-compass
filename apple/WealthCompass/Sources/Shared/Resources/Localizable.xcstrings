        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ ייעלם מהעסקאות החוזרות ולא יוכנסו מופעים עתידיים באופן אוטומטי."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ आवर्ती लेनदेन से गायब हो जाएगा और भविष्य में कोई भी घटना स्वचालित रूप से नहीं डाली जाएगी।"
