        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "שיעורי הייחוס של ה-ECB מתרעננים אוטומטית ומאוחסנים במטמון מקומי לשימוש לא מקוון."
          }
        },
        "hi" : {
          "stringUnit" : {
