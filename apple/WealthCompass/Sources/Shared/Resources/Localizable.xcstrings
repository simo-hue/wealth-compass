          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld på grunn av gjentakende transaksjoner ble lagt til kontantstrøm."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld verschuldigde terugkerende transacties zijn toegevoegd aan de cashflow."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
