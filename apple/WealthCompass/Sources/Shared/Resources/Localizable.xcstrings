    "\n\n%lld due recurring transactions were added to Cash Flow." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld تمت إضافة المعاملات المتكررة المستحقة إلى التدفق النقدي."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld les transaccions recurrents degudes s'han afegit a Flux d'efectiu."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Do Cash Flow bylo přidáno %lld splatné opakované transakce."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld på grund af tilbagevendende transaktioner blev tilføjet til Cash Flow."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld fällige wiederkehrende Transaktionen wurden dem Cashflow hinzugefügt."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Οι οφειλόμενες επαναλαμβανόμενες συναλλαγές %lld προστέθηκαν στο Cash Flow."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld se agregaron transacciones recurrentes debidas al flujo de caja."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld se agregaron transacciones recurrentes debidas al flujo de caja."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld erääntyvät toistuvat tapahtumat lisättiin kassavirtaan."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld les transactions récurrentes dues ont été ajoutées au flux de trésorerie."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld עקב עסקאות חוזרות נוספו לתזרים המזומנים."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld देय आवर्ती लेनदेन को कैश फ्लो में जोड़ा गया।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld dospjelih ponavljajućih transakcija dodano je u Cash Flow."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld esedékes ismétlődő tranzakciók hozzáadva a Cash Flow-hoz."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld transaksi berulang yang jatuh tempo ditambahkan ke Arus Kas."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld le transazioni ricorrenti dovute sono state aggiunte al flusso di cassa."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld 期日の定期取引がキャッシュ フローに追加されました。"
