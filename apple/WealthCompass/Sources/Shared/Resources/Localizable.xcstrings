        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto elimina %@ de sus categorías %@ personalizadas. Las transacciones existentes que utilicen esta categoría mantendrán su etiqueta actual."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela supprime %@ de vos catégories %@ personnalisées. Les transactions existantes utilisant cette catégorie conserveront leur étiquette actuelle."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ciò rimuove %@ dalle tue categorie %@ personalizzate. Le transazioni esistenti che utilizzano questa categoria manterranno la loro etichetta attuale."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这将从您的自定义 %@ 类别中删除 %@。使用此类别的现有交易将保留其当前标签。"
          }
        }
      }
    },
