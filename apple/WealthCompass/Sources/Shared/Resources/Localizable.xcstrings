    "%lld transactions, %lld recurring schedules, %lld investments, %lld crypto holdings, %lld liabilities, and %lld snapshots were imported." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم استيراد %lld المعاملات، %lld الجداول المتكررة، %lld الاستثمارات، %lld مقتنيات العملات المشفرة، %lld الالتزامات، و%lld اللقطات."
          }
        },
        "ca" : {
          "stringUnit" : {
