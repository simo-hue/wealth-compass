    "Merge adds new records and updates matching IDs. Replace clears current local finance data before importing." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يقوم الدمج بإضافة سجلات جديدة وتحديثات مطابقة للمعرفات. يقوم الاستبدال بمسح بيانات التمويل المحلي الحالية قبل الاستيراد."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La combinació afegeix nous registres i actualitza els ID coincidents. Reemplaça esborra les dades actuals de finances locals abans d'importar-les."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sloučit přidává nové záznamy a aktualizuje odpovídající ID. Nahradit vymaže aktuální místní finanční data před importem."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Flet tilføjer nye registreringer og opdaterer matchende id'er. Erstat sletter aktuelle lokale finansdata før import."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durch Zusammenführen werden neue Datensätze hinzugefügt und übereinstimmende IDs aktualisiert. Durch Ersetzen werden die aktuellen lokalen Finanzdaten vor dem Import gelöscht."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Το Merge προσθέτει νέες εγγραφές και ενημερώνει τα αντίστοιχα αναγνωριστικά. Το Replace διαγράφει τα τρέχοντα τοπικά οικονομικά δεδομένα πριν από την εισαγωγή."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fusionar agrega nuevos registros y actualiza las ID coincidentes. Reemplazar borra los datos financieros locales actuales antes de importar."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fusionar agrega nuevos registros y actualiza las ID coincidentes. Reemplazar borra los datos financieros locales actuales antes de importar."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yhdistäminen lisää uusia tietueita ja päivittää vastaavia tunnuksia. Korvaa tyhjentää nykyiset paikalliset taloustiedot ennen tuontia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La fusion ajoute de nouveaux enregistrements et met à jour les identifiants correspondants. Remplacer efface les données financières locales actuelles avant l’importation."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "מיזוג מוסיף רשומות חדשות ומעדכן מזהים תואמים. החלפה מנקה את נתוני הכספים המקומיים העדכניים לפני הייבוא."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "मर्ज नए रिकॉर्ड जोड़ता है और मेल खाने वाली आईडी अपडेट करता है। आयात करने से पहले रिप्लेस वर्तमान स्थानीय वित्त डेटा को साफ़ करता है।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spajanje dodaje nove zapise i ažurira podudarne ID-ove. Zamijeni briše trenutne lokalne podatke o financijama prije uvoza."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Az egyesítés új rekordokat ad hozzá, és frissíti a megfelelő azonosítókat. A Csere törli az aktuális helyi pénzügyi adatokat az importálás előtt."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Penggabungan menambahkan catatan baru dan memperbarui ID yang cocok. Ganti menghapus data keuangan lokal saat ini sebelum mengimpor."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unisci aggiunge nuovi record e aggiorna gli ID corrispondenti. Sostituisci cancella i dati finanziari locali correnti prima dell'importazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Merge は新しいレコードを追加し、一致する ID を更新します。 Replace は、インポートする前に現在の地方財務データを消去します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "병합은 새 레코드를 추가하고 일치하는 ID를 업데이트합니다. 바꾸기는 가져오기 전에 현재 지역 금융 데이터를 지웁니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gabung menambah rekod baharu dan mengemas kini ID yang sepadan. Ganti mengosongkan data kewangan tempatan semasa sebelum mengimport."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Merge legger til nye poster og oppdaterer samsvarende IDer. Erstatt sletter gjeldende lokale finansdata før import."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Samenvoegen voegt nieuwe records toe en werkt overeenkomende ID's bij. Vervangen wist de huidige lokale financiële gegevens voordat deze worden geïmporteerd."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
