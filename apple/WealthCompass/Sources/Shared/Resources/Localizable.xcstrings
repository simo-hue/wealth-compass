    "Wealth Compass records due occurrences while the app is active. If the app was closed, missed occurrences are added automatically the next time it opens." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
