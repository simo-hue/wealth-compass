    "The iCloud account changed. Sync was disabled to prevent data from crossing accounts. Enable it again to sync with the current account." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم تغيير حساب iCloud. تم تعطيل المزامنة لمنع البيانات من عبور الحسابات. قم بتمكينه مرة أخرى للمزامنة مع الحساب الحالي."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "The iCloud account changed. Sync was disabled to prevent data from crossing accounts. Enable it again to sync with the current account."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "The iCloud account changed. Sync was disabled to prevent data from crossing accounts. Enable it again to sync with the current account."
