    "Add a holding to track its value and performance." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أضف ملكية لتتبع قيمتها وأدائها."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Afegiu una participació per fer un seguiment del seu valor i rendiment."
          }
