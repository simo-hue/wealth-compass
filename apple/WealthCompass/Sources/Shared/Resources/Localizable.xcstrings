          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "יובאו עסקאות %lld, %lld לוחות זמנים חוזרים, %lld השקעות, %lld אחזקות קריפטו, %lld התחייבויות ו%lld צילומי מצב."
