          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Merge adaugă noi înregistrări și actualizează ID-uri. Înlocuire șterge datele actuale privind finanțele locale înainte de importare."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Слияние добавляет новые записи и обновляет соответствующие идентификаторы. Заменить очищает текущие данные о местных финансах перед импортом."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zlúčiť pridáva nové záznamy a aktualizuje zodpovedajúce ID. Nahradiť vymaže aktuálne miestne finančné údaje pred importovaním."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Merge lägger till nya poster och uppdaterar matchande ID:n. Ersätt rensar aktuell lokal ekonomidata innan import."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ผสานเพิ่มบันทึกใหม่และอัปเดตรหัสที่ตรงกัน แทนที่จะล้างข้อมูลการเงินในท้องถิ่นปัจจุบันก่อนนำเข้า"
