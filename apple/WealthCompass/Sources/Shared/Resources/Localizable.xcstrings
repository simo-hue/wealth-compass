            "value" : "ईसीबी संदर्भ दरें स्वचालित रूप से ताज़ा की जाती हैं और ऑफ़लाइन उपयोग के लिए स्थानीय रूप से कैश की जाती हैं।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
